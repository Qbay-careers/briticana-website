# Get project ID from https://www.sanity.io/manage → Project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: draft mode / server writes only (never expose write token to the browser)
SANITY_API_TOKEN=
NEXT_PUBLIC_SITE_URL=

# Student portal sign-in (server-only; never shown in the UI). Required for /login → /dashboard.
# If the password contains #, wrap the whole value in double quotes or dotenv treats the rest as a comment.
DEMO_STUDENT_EMAIL=
DEMO_STUDENT_PASSWORD=

# Application form → Google Sheets (server-only). Required for POST /api/applications.
# 1. Google Cloud → create project → enable "Google Sheets API".
# 2. Create a Service Account → add a JSON key → copy the values below.
# 3. Open the target Google Sheet → Share → give the service account email "Editor".
# 4. Add a header row to the sheet matching APPLICATION_SHEET_HEADERS in src/lib/applications/googleSheets.ts.
GOOGLE_SHEETS_SPREADSHEET_ID=
# Optional worksheet/tab name (defaults to "Applications").
GOOGLE_SHEETS_TAB_NAME=Applications
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep the literal \n escapes and wrap the whole value in double quotes.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Local dev alternative: path to the downloaded service account JSON (production should use PRIVATE_KEY above).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./briticana-applications-43129e1f7b90.json

# After setting PROJECT_ID: in Sanity Manage → API → CORS origins, add:
#   http://localhost:3000
#   and your production URL (required for Studio at /studio and browser fetches).
