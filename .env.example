# Get project ID from https://www.sanity.io/manage → Project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: draft mode / server writes only (never expose write token to the browser)
SANITY_API_TOKEN=
NEXT_PUBLIC_SITE_URL=

# Student portal sign-in (server-only; never shown in the UI). Required for /login → /dashboard.
# If the password contains #, wrap the whole value in double quotes or dotenv treats the rest as a comment.
DEMO_STUDENT_EMAIL=
DEMO_STUDENT_PASSWORD=

# Application form → Google Sheets (server-only). Required for POST /api/applications.
# 1. Google Cloud → enable "Google Sheets API".
# 2. Create a Service Account → JSON key.
# 3. Google Sheet → Share with service account email as Editor.
#    Row 1 headers: see APPLICATION_SHEET_HEADERS in src/lib/applications/applicationTypes.ts
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Applications

# Resume uploads → Cloudflare R2 (S3-compatible). Free tier: 10 GB storage.
# 1. Cloudflare Dashboard → R2 → Create bucket (e.g. briticana-applications).
# 2. R2 → Manage R2 API Tokens → Create token → copy Access Key ID + Secret Access Key.
# 3. R2_ACCOUNT_ID = Cloudflare Account ID (Dashboard home or R2 Overview — NOT the Access Key ID).
#    Endpoint will be: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# 4. Optional: enable public access on bucket → copy r2.dev URL for R2_PUBLIC_BASE_URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
# Optional: override S3 endpoint if needed (e.g. https://abc123.r2.cloudflarestorage.com)
R2_S3_ENDPOINT=

# Google service account credentials — use ONE of these (JSON recommended for Vercel):
#   node -e "console.log(JSON.stringify(require('./your-key.json')))"
GOOGLE_SERVICE_ACCOUNT_JSON=
# Base64 alternative (paste-proof on Vercel):
#   node -e "console.log(Buffer.from(JSON.stringify(require('./your-key.json'))).toString('base64'))"
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# Local dev: path to JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./briticana-applications-43129e1f7b90.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# After setting PROJECT_ID: in Sanity Manage → API → CORS origins, add:
#   http://localhost:3000
#   and your production URL (required for Studio at /studio and browser fetches).
