# Get project ID from https://www.sanity.io/manage → Project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: draft mode / server writes only (never expose write token to the browser)
SANITY_API_TOKEN=
NEXT_PUBLIC_SITE_URL=

# After setting PROJECT_ID: in Sanity Manage → API → CORS origins, add:
#   http://localhost:3000
#   and your production URL (required for Studio at /studio and browser fetches).
